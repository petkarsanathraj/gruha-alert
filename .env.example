# Copy to .env.local and fill in when your accounts exist. The site runs WITHOUT
# any of these (it falls back to data/seed.json).

# Supabase (Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=          # public read key (used by the website)
SUPABASE_SERVICE_KEY=       # secret key (used by worker + subscribe API)

# Public site URL (used for SEO canonical/sitemap)
NEXT_PUBLIC_SITE_URL=https://gruha-alert.vercel.app

# Google AdSense (after approval): ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=
